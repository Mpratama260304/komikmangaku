# Environment variables for mirror proxy
# Copy this file to .env and adjust values

# Origin site to mirror
ORIGIN_HOST=komik.mangaku.asia
ORIGIN_PROTOCOL=https

# Your mirror domain (WAJIB diisi dengan domain mirror kamu)
MIRROR_DOMAIN=yourdomain.com

# Server port
PORT=3000

# Cache TTL in seconds (default 5 minutes)
CACHE_TTL=300

# Max cache entries in memory
MAX_CACHE_ENTRIES=500

# Rate limit per IP per 15 minutes
RATE_LIMIT=200
